{
    "name": "scientias/youtube-carrousel",
    "description": "Dev tooling for the Scientias YouTube Carrousel plugin (coding standards only; not shipped with the plugin).",
    "license": "proprietary",
    "type": "project",
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
